# Javi — пример переменных окружения (локально скопируй в .env)
SECRET_KEY=django-insecure-dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://javi.serbito.rs

# БД. Локально можно оставить пустым (sqlite). Прод — Cloud SQL serbitodb, база javi:
# DATABASE_URL=postgres://javi:PASSWORD@/javi?host=/cloudsql/serbito:europe-west1:serbitodb
# Локальный Postgres в Docker:
# DATABASE_URL=postgres://javi:javi@127.0.0.1:5432/javi
